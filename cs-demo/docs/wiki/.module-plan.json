{
  "modules": [
    {
      "name": "App Shell & Layout",
      "description": "Top-level application layout, root page, and global providers including theming.",
      "components": [
        "cs-demo/app/layout.tsx",
        "cs-demo/app/page.tsx",
        "cs-demo/providers/theme-provider.tsx"
      ]
    },
    {
      "name": "Boot Flow",
      "description": "Initial boot/onboarding page for the application.",
      "components": [
        "cs-demo/app/boot/page.tsx"
      ]
    },
    {
      "name": "Repository Dashboard",
      "description": "Repository detail pages including layout, overview, docs, insights, issues, pulls, and review views.",
      "components": [
        "cs-demo/app/repo/[id]/layout.tsx",
        "cs-demo/app/repo/[id]/page.tsx",
        "cs-demo/app/repo/[id]/docs/page.tsx",
        "cs-demo/app/repo/[id]/insights/page.tsx",
        "cs-demo/app/repo/[id]/issues/page.tsx",
        "cs-demo/app/repo/[id]/pulls/page.tsx",
        "cs-demo/app/repo/[id]/review/page.tsx"
      ]
    },
    {
      "name": "Settings",
      "description": "Application settings page.",
      "components": [
        "cs-demo/app/settings/page.tsx"
      ]
    },
    {
      "name": "Shared Components",
      "description": "Reusable application-level components such as header, repo card, dialogs, and theme switcher.",
      "components": [
        "cs-demo/components/app-header.tsx",
